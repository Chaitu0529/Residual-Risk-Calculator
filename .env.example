# =============================================
# Tool-114 Residual Risk Calculator
# Environment Variables Example
# =============================================

# --- PostgreSQL ---
POSTGRES_DB=residual_risk_db
POSTGRES_USER=riskadmin
POSTGRES_PASSWORD=StrongP@ssw0rd123!

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=RedisP@ssw0rd123!

# --- JWT ---
JWT_SECRET=your-256-bit-super-secret-jwt-signing-key-change-in-production
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# --- Backend ---
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
VITE_AI_SERVICE_URL=http://localhost:5000

# --- AI Service ---
GROQ_API_KEY=your_groq_api_key_here
AI_SERVICE_PORT=5000
FLASK_ENV=production

# --- Email (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@tool114.com

# --- File Upload ---
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=5MB
